{
  "name": "moksha-seva-backend",
  "version": "1.0.0",
  "description": "Moksha Seva Backend API with Form Management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate-postman": "node generatePostman.js",
    "generate-sitemap": "node -e \"require('./services/sitemapService').saveSitemap()\"",
    "seed": "node seedPageConfigs.js",
    "seed:admin": "node seedAdmin.js",
    "seed:moksha-admin": "node seedMokshaAdmin.js",
    "seed:seo": "node seedSEO.js",
    "seed:all": "npm run seed && npm run seed:admin && npm run seed:seo",
    "postinstall": "npm run seed:all"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "html-pdf-node": "^1.0.8",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.4",
    "puppeteer": "^24.39.1",
    "razorpay": "^2.9.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "moksha-seva",
    "forms",
    "api",
    "backend"
  ],
  "author": "Moksha Seva Team",
  "license": "MIT"
}
